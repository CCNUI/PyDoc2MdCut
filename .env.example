# ==================== 输入 / 输出目录 ====================
# 不填这两项时必须在命令行用 --input / --output 指定；
# 填了之后可以直接 `python convert.py` 跑。CLI 优先级最高。
# 支持相对路径（相对运行目录）或绝对路径。
# Windows 示例：INPUT_DIR=D:\projects\my_docs
# Linux  示例：INPUT_DIR=/home/me/projects/my_docs
INPUT_DIR=
OUTPUT_DIR=./out

# ==================== 基础参数 ====================
# 单卷最大字节数（MB），CLI --max-size-mb 可覆盖
MAX_SIZE_MB=19

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# CSV 转 Markdown 表格时的最大行数，超过截断
CSV_MAX_ROWS=200

# 图片型 PDF 检测阈值：字符数/页数 < 此值视为图片型
SCANNED_PDF_CHAR_PER_PAGE=50

# ==================== 百度 OCR 配置 ====================
# 是否启用 OCR（true/false）。false 时图片文件走跳过路径，不会因为缺 key 报错
OCR_ENABLED=false

# 百度智能云 应用 API Key / Secret Key
# 申请地址: https://console.bce.baidu.com/ai/#/ai/ocr/app/list
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# OCR 引擎类型:
#   accurate_basic = 通用文字识别（高精度版），识别率高，QPS 低，付费配额少
#   general_basic  = 通用文字识别（标准版），免费额度更多
OCR_ENGINE=accurate_basic

# OCR 单图最大重试次数
OCR_MAX_RETRIES=3

# OCR 调用之间的最小间隔（秒），用来规避 QPS 限制
OCR_MIN_INTERVAL=0.5

# OCR token 缓存文件路径（access_token 30 天有效，缓存避免重复获取）
OCR_TOKEN_CACHE=.baidu_token_cache.json

# 支持 OCR 的图片扩展名（逗号分隔，小写不带点）
OCR_IMAGE_EXTS=png,jpg,jpeg,gif,webp,bmp,tiff

# 单张图片最大字节数（百度 API 限制 4MB），超过的图片记录到报告并跳过 OCR
OCR_MAX_IMAGE_BYTES=4194304

# ==================== 修改日期筛选（可选）====================
# 启用后，只处理 mtime 在 [MTIME_AFTER, MTIME_BEFORE] 闭区间内的文件
# CLI 也可用 --filter-mtime / --no-filter-mtime 临时覆盖
MTIME_FILTER_ENABLED=false

# 起止日期：支持 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS；留空表示不限
# 例：只处理 2024 年的文件
#   MTIME_AFTER=2024-01-01
#   MTIME_BEFORE=2024-12-31 23:59:59
MTIME_AFTER=
MTIME_BEFORE=

# ==================== 日志类文件截取 ====================
# 仅影响 .log / .tlog / .rlog 这三类。
# 单文件原始字节数超过此值时，转换结果会按"头+尾"截取，中间标记 "... TRUNCATED N bytes ..."
# 单位是字节；默认 10 MiB
LOG_FILE_MAX_BYTES=10485760

# 截断时头部占比（0~1）。例如 0.5 表示头尾各占一半
LOG_TRUNCATE_HEAD_RATIO=0.5

# ==================== 中间过程文件保留 ====================
# 启用后，每个文件的转换结果会单独保存一份到 <output>/intermediate/<file_id>__<safe_name>.md
# 同时附带 *.extra.json（机器友好的元信息）和 INDEX.md（索引）
# CLI 也可用 --keep-intermediate / --no-keep-intermediate 临时覆盖
KEEP_INTERMEDIATE_FILES=false

# 中间产物子目录名（相对 --output 目录）
INTERMEDIATE_SUBDIR=intermediate

# ==================== 文件元信息附注（可选）====================
# 启用后会计算每个文件的内容哈希（SHA-256 / SHA-1 / MD5），并按 FILE_METADATA_POSITION
# 把"哈希 / 修改日期 / 创建日期 / 大小"附在 TOC、正文文件头、或两处。
# CLI 也可用 --with-metadata / --no-metadata 临时覆盖。
FILE_METADATA_ENABLED=false

# 哈希算法: sha256 / sha1 / md5
# - sha256（推荐，安全且差异分辨率高）
# - sha1（更快，碰撞已不安全但用作内容指纹仍然够用）
# - md5（最快，仅在大量文件且需要极速时使用，不要用于安全场景）
FILE_HASH_ALGO=sha256

# 元信息显示位置: toc / body / both / none
# - toc:  仅在目录条目末尾以紧凑格式追加（例 `1.2 MB · m:2025-03-15 · sha256:a1b2c3d4`）
# - body: 仅在每个文件正文头(FILE START 块)中以多行 verbose 格式追加
# - both: 两处都加
# - none: 不显示元信息（即使 enabled=true；常用于"开了查重但不想污染目录/正文"）
# CLI: --metadata-position {toc|body|both|none}
FILE_METADATA_POSITION=body

# 显示哪些字段（任一为 false 即跳过该项；FILE_METADATA_ENABLED=false 时整体不显示）
FILE_METADATA_SHOW_HASH=true
FILE_METADATA_SHOW_MTIME=true
FILE_METADATA_SHOW_CTIME=true
FILE_METADATA_SHOW_SIZE=true

# 大于此字节数的文件不计算哈希（0 = 不限）。仅影响元信息中"哈希"和"查重"两项。
# 例如：FILE_HASH_MAX_BYTES=104857600  # 100 MB 以上不算哈希
FILE_HASH_MAX_BYTES=0

# TOC 紧凑显示时的哈希前缀长度（4-64）；仅影响显示，不影响实际计算
FILE_HASH_SHORT_LEN=16

# ==================== 重复文件检测（可选）====================
# 启用后基于 FILE_HASH_ALGO 计算的内容哈希查找重复文件。
# 在每卷 merged_part_*.md 的"目录"之后会插入 AI 友好的查重报告，
# 包含每组的主副本(MAIN) / 副本(DUP)关系和机器可读索引块。
# 启用此项会自动开启 FILE_METADATA_ENABLED（即便用户未显式设置）。
# CLI 也可用 --dedup / --no-dedup 临时覆盖。
DUPLICATE_DETECTION_ENABLED=false

# ==================== 通用文件截取（TRUNC_*，可选）====================
# 把文件砍成「头 xMB + 中间随机 N 个 xMB 块 + 尾 xMB」，
# 适合把大量大文件压到可控大小后喂给 LLM。
#
# 完整的默认值在仓库内的 .env.default 中；本文件只列你最常需要调整的项。
# 优先级：扩展名(.xxx) > kind > default
# x 支持 0 / 小数 / 整数；x=0 表示该部分不取。
#
# 1) 全局总开关（false = 所有类型都不截）
# TRUNC_ENABLED=true
#
# 2) 随机种子（同种子 + 同文件名 ⇒ 结果可复现，便于增量上传 / 调试）
# TRUNC_SEED=0
#
# 3) 按 kind 调整（覆盖 .env.default 中该 kind 的默认）
#    示例：把日志类截得更激进
# TRUNC_KIND_LOG_ENABLED=true
# TRUNC_KIND_LOG_HEAD_MB=1
# TRUNC_KIND_LOG_TAIL_MB=1
# TRUNC_KIND_LOG_CHUNK_MB=0.5
# TRUNC_KIND_LOG_MIDDLE_CHUNKS=2
#
# 4) 按扩展名精调（最高优先级；可针对同 kind 下的不同扩展名）
#    示例：只对 .log 截，对 .rlog 不截（即便都属于日志类）
# TRUNC_EXT_LOG_ENABLED=true
# TRUNC_EXT_LOG_HEAD_MB=2
# TRUNC_EXT_LOG_TAIL_MB=2
# TRUNC_EXT_LOG_CHUNK_MB=1
# TRUNC_EXT_LOG_MIDDLE_CHUNKS=2
# TRUNC_EXT_RLOG_ENABLED=false

# ==================== 按文件类型的大小筛选（SIZE_FILTER_*，可选）=========
# 扫描阶段直接根据「类型 + 大小」过滤；过大或过小的文件直接跳过。
# 单位 MB；-1 或 false 表示「关闭该项筛选」。优先级同上。
#
# 1) 全局总开关
# SIZE_FILTER_ENABLED=true
#
# 2) 默认（未列出的类型都走这里）
# SIZE_FILTER_DEFAULT_MIN_MB=-1
# SIZE_FILTER_DEFAULT_MAX_MB=-1
#
# 3) 按 kind 设置
#    示例：日志类只接受 1-50 MB
# SIZE_FILTER_KIND_LOG_MIN_MB=1
# SIZE_FILTER_KIND_LOG_MAX_MB=50
#
# 4) 按扩展名设置
#    示例：图片限 0.1-4 MB
# SIZE_FILTER_EXT_PNG_MIN_MB=0.1
# SIZE_FILTER_EXT_PNG_MAX_MB=4

# ==================== 创建日期筛选（可选）====================
# 与 mtime 类似，但用文件「创建时间」做筛选。
# 注意：Linux ext4 等老文件系统提供的是「元数据变更时间」(近似创建时间)。
# 拿不到 ctime 的文件默认放行。
# CTIME_FILTER_ENABLED=true
# CTIME_AFTER=2024-01-01
# CTIME_BEFORE=2024-12-31 23:59:59

# ==================== 进目录扩展名 / kind 筛选 ===============
# 在「全量枚举」之后、提取流水线之前应用；决定哪些文件有资格进入提取。
# 多个值用逗号分隔；任一为空 = 不限制。blacklist 优先于 whitelist。
#
# 示例 A：只接受 Python 代码 + Markdown
# ELIGIBILITY_INCLUDE_KINDS=code_py,markdown
#
# 示例 B：拒绝所有 log 类文件
# ELIGIBILITY_EXCLUDE_KINDS=log,tlog,rlog
#
# 示例 C：用扩展名拒绝某几种
# ELIGIBILITY_EXCLUDE_EXTS=.tlog,.rlog
#
# 示例 D：对未识别扩展名直接拒，不进流水线占位
# ELIGIBILITY_UNSUPPORTED_POLICY=reject

# ==================== 完整文件目录（全量枚举清单）============
# 不受任何筛选影响的「全量目录」，含 byte 精度大小 + size_class 标签，
# 便于 LLM 按 (路径, byte 数) 做查重——大于 10MB 的文件精确字节几乎是唯一指纹。
# FULL_INVENTORY_IN_MERGED=true   # 写到每卷 merged_part_*.md 第 1 卷顶部
# FULL_INVENTORY_IN_REPORT=true   # 也写到 conversion_report.md
