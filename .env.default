# =============================================================================
# .env.default — 工具的默认配置（仓库内提交）
# -----------------------------------------------------------------------------
# 加载顺序：先加载用户 .env，再加载本文件做兜底（不覆盖用户已设置的项）。
# 用户 .env 中显式写了的项 → 用用户的；没写的项 → 用本文件的默认值。
#
# **本文件的所有默认值都是面向「上传给 LLM 对话框」场景调优的推荐值**，
# 目标：每卷 10 MB、最多 19 卷、总 ≤ 190 MB 的 AI 对话框上传场景。
# 优化方向：
#   - 尽量多塞「不同文件」（文件名常常乱，靠 size 识别）
#   - 单文件极致精简：
#       * 文本 / 文档（pdf/docx/xlsx/wps/html/md/txt/json/csv/log/...）：~10 KB 总量
#         足够让 LLM 识别格式、读到开头/结尾、判断大致内容主题
#       * 二进制特征文件（image/exe/archive_*）：~1 KB 头部
#         足够让 LLM 看到文件格式签名 / 头部元信息
#   - 大量垃圾（0B / __pycache__ / .tmp / .lock 等）直接物理跳过，不进入全量目录
#   - 默认关闭 hash 校验：内容指纹只在显式开启 dedup 时才算，节省扫描成本
#
# 通用值约定：
#   开关：true/false/1/0/yes/no/on/off
#   大小数值默认单位 MB；x 支持 0 / 小数 / 整数：
#     - 0   该部分不取
#     - -1  关闭该项筛选（仅大小筛选有效）
#     - false 等同 -1
#   备注: 10 KB ≈ 0.01 MB；1 KB ≈ 0.001 MB
# =============================================================================


# ===========================================================================
# 一、基础参数 ===============================================================
# ===========================================================================

# ----- 输入 / 输出目录 -----
# 优先级：CLI --input / --output > 本配置 > 报错
# 留空表示「必须在命令行显式指定」；填了之后可不带 --input/--output 直接运行。
# 支持相对路径（相对 convert.py 的运行目录）或绝对路径。
INPUT_DIR=Test1
OUTPUT_DIR=out

# 单卷大小：10 MB（题目约束；小 m，10*1024*1024 字节）
MAX_SIZE_MB=10

# 默认日志级别
LOG_LEVEL=INFO

# CSV 转 markdown 表格的最大行数；调大让 CSV 信息更完整
# 200 太保守；500 行通常能保留大多数小型表格的全貌
CSV_MAX_ROWS=500

# 图片型 PDF 检测阈值：平均每页字符 < 此值 → 判为扫描件
SCANNED_PDF_CHAR_PER_PAGE=50

# 输出目录自动加 _YYYYMMDD_HHMMSS 时间戳后缀（默认开）
# 关闭后直接用 --output 给的路径
OUTPUT_TIMESTAMP_SUFFIX=true


# ===========================================================================
# 二、百度 OCR ===============================================================
# ===========================================================================
# 默认关闭：未填 API key 也不会报错；想用图片 OCR 时改 true 并填 key
OCR_ENABLED=false
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
OCR_ENGINE=accurate_basic
OCR_MAX_RETRIES=3
OCR_MIN_INTERVAL=0.5
OCR_TOKEN_CACHE=.baidu_token_cache.json
OCR_IMAGE_EXTS=png,jpg,jpeg,gif,webp,bmp,tiff
# 百度 API 单图限制 4MB
OCR_MAX_IMAGE_BYTES=4194304


# ===========================================================================
# 三、修改日期 / 创建日期筛选 ================================================
# ===========================================================================
MTIME_FILTER_ENABLED=false
MTIME_AFTER=
MTIME_BEFORE=

CTIME_FILTER_ENABLED=false
CTIME_AFTER=
CTIME_BEFORE=


# ===========================================================================
# 四、枚举层「物理跳过」清单 =================================================
# ---------------------------------------------------------------------------
# 这些路径/文件名/后缀会在枚举阶段直接跳过，不进入「全量目录」也不进入提取。
# 内置默认清单已经包含常见垃圾（__pycache__ / node_modules / .git / Thumbs.db
# / .pyc / .swp / build / dist / target 等等），本文件这里只让用户**追加**。
# 多个用逗号分隔。
# ---------------------------------------------------------------------------

# 追加的「垃圾目录名」（任何祖先目录命中即跳过该文件）
# 内置默认包括: __pycache__ .venv venv env .pytest_cache .mypy_cache .ruff_cache
#               node_modules .next .nuxt build dist out target bin obj
#               .gradle .maven .idea .vscode .vs .git .svn .hg
#               Temp temp tmp .cache  $RECYCLE.BIN  System Volume Information
#               .Trash .Trashes  .ipynb_checkpoints
# 如果你想再加自己项目特有的垃圾目录，在这里补：
PURGE_DIR_NAMES_EXTRA=

# 追加的「具体垃圾文件名」
# 内置默认: .DS_Store Thumbs.db desktop.ini ehthumbs.db .gitignore .gitkeep
PURGE_FILENAMES_EXTRA=

# 追加的「垃圾后缀」（自动小写并加点）
# 内置默认: .pyc .pyo .class .o .obj .swp .swo .lock
# 推荐再加：.tmp .temp .bak .old .part .crdownload .partial .download
PURGE_SUFFIXES_EXTRA=.tmp,.temp,.bak,.old,.part,.crdownload,.partial,.download


# ===========================================================================
# 五、进目录扩展名 / kind 筛选（资格层）=====================================
# ---------------------------------------------------------------------------
# 默认放行所有 kind，仅拒绝几个「信息密度极低」的扩展：
#   - .dat / .bin / .iso / .img / .vmdk —— 黑箱二进制，无文件头解析
#   - 字体 .ttf / .otf —— 无意义字节
#   - 音视频 .mp3 / .mp4 / .avi / .mov / .wav / .flac —— 流媒体本工具不解码
#
# 注：.exe / .dll / .zip / .7z / .rar / .tar / .gz 等会**有专门解析**
#     （PE 头 / 文件列表），所以**不**拒绝它们。
# 注：.tmp / .bak / .lock 已经在 PURGE_SUFFIXES_EXTRA 物理跳过，无需在此再拒。
# ---------------------------------------------------------------------------
ELIGIBILITY_INCLUDE_EXTS=
ELIGIBILITY_INCLUDE_KINDS=
ELIGIBILITY_EXCLUDE_EXTS=.dat,.bin,.iso,.img,.vmdk,.vdi,.qcow2,.ttf,.otf,.woff,.woff2,.mp3,.mp4,.avi,.mov,.mkv,.wav,.flac,.wma,.aac,.m4a,.ogg,.opus,.webm
ELIGIBILITY_EXCLUDE_KINDS=
# 未识别扩展名的处理：默认 allow（在合并 MD 中保留占位 + 列入跳过报告，便于查重）
ELIGIBILITY_UNSUPPORTED_POLICY=allow


# ===========================================================================
# 六、完整文件目录（全量枚举清单，不受任何筛选影响）=========================
# ---------------------------------------------------------------------------
# 给 LLM 一个全量目录视图，含 byte 精度大小和 size_class 标签。
# 大于 10MB 的文件，精确字节几乎是唯一指纹 → 配合乱名文件做查重。
# ---------------------------------------------------------------------------
FULL_INVENTORY_IN_MERGED=true
FULL_INVENTORY_IN_REPORT=true


# ===========================================================================
# 七、旧式日志截取（保留兼容；新机制建议用下方 TRUNC_*）====================
# ===========================================================================
LOG_FILE_MAX_BYTES=10485760
LOG_TRUNCATE_HEAD_RATIO=0.5


# ===========================================================================
# 八、中间产物 / 元信息 / 查重 ==============================================
# ---------------------------------------------------------------------------
# 默认关闭 hash 校验：
#   - hash 计算需要把每个文件全量读一遍，几十万小文件成本不可忽视
#   - 默认场景（首次扫盘 / 快速看一眼）不需要查重；想要时显式开 DUPLICATE_DETECTION_ENABLED
#   - 元信息中的 size / mtime / ctime 仍然显示（这些是 stat() 免费给的）
# 中间产物默认关：会成倍占磁盘，且 LLM 不需要看。
# ---------------------------------------------------------------------------
KEEP_INTERMEDIATE_FILES=false
INTERMEDIATE_SUBDIR=intermediate

# 元信息附注：默认开（让 LLM 看到每文件的 大小 / 时间）
FILE_METADATA_ENABLED=true
# sha1 比 sha256 快一倍，对内容指纹场景完全够用（不是安全场景）
FILE_HASH_ALGO=sha1
# both：TOC 行末有紧凑串 + 正文头有 verbose 块；信息密度最高
FILE_METADATA_POSITION=both
# *** 默认关掉 hash 显示：不计算、不显示，避免几十万小文件的全量读取开销 ***
FILE_METADATA_SHOW_HASH=false
FILE_METADATA_SHOW_MTIME=true
FILE_METADATA_SHOW_CTIME=true
FILE_METADATA_SHOW_SIZE=true
# 大于 100MB 的文件不算 hash（避免拖慢；超大文件本来就近乎唯一）
FILE_HASH_MAX_BYTES=104857600
FILE_HASH_SHORT_LEN=12

# *** 查重默认关：开启会强制把所有文件读一遍算 hash ***
# 想合并重复内容时再 --dedup 或在 .env 中开启
DUPLICATE_DETECTION_ENABLED=false


# ===========================================================================
# 九、通用文件截取（TRUNC_*）—— 头 + 中间随机块 + 尾 =========================
# ---------------------------------------------------------------------------
# **核心策略：单文件极致精简**
#   - 文本 / 文档：~10 KB 总量（头 5KB + 尾 5KB；无中间样本）
#   - 二进制特征：~1 KB 头部即可（不取尾、不取中段）
# 这套预算让一卷 10MB 能塞 1000+ 个文件特征，配合 size+mtime+全量目录
# 已足够让 AI 看清「都有哪些文件、各自什么类型/规模/大致内容」。
# 优先级：扩展名(.xxx) > kind > default
# 备注: 10 KB ≈ 0.01 MB；5 KB ≈ 0.005 MB；1 KB ≈ 0.001 MB
# ===========================================================================

# --- 全局开关 ---
TRUNC_ENABLED=true
TRUNC_SEED=0

# --- 默认（未列出的类型）—— 当作文本对待：~10 KB ---
TRUNC_DEFAULT_ENABLED=true
TRUNC_DEFAULT_HEAD_MB=0.005
TRUNC_DEFAULT_TAIL_MB=0.005
TRUNC_DEFAULT_CHUNK_MB=0
TRUNC_DEFAULT_MIDDLE_CHUNKS=0

# --- 文档类（pdf/docx/xlsx/wps）：~10 KB ---
TRUNC_KIND_PDF_ENABLED=true
TRUNC_KIND_PDF_HEAD_MB=0.005
TRUNC_KIND_PDF_TAIL_MB=0.005
TRUNC_KIND_PDF_CHUNK_MB=0
TRUNC_KIND_PDF_MIDDLE_CHUNKS=0

TRUNC_KIND_DOCX_ENABLED=true
TRUNC_KIND_DOCX_HEAD_MB=0.005
TRUNC_KIND_DOCX_TAIL_MB=0.005
TRUNC_KIND_DOCX_CHUNK_MB=0
TRUNC_KIND_DOCX_MIDDLE_CHUNKS=0

TRUNC_KIND_XLSX_ENABLED=true
TRUNC_KIND_XLSX_HEAD_MB=0.005
TRUNC_KIND_XLSX_TAIL_MB=0.005
TRUNC_KIND_XLSX_CHUNK_MB=0
TRUNC_KIND_XLSX_MIDDLE_CHUNKS=0

TRUNC_KIND_WPS_ENABLED=true
TRUNC_KIND_WPS_HEAD_MB=0.005
TRUNC_KIND_WPS_TAIL_MB=0.005
TRUNC_KIND_WPS_CHUNK_MB=0
TRUNC_KIND_WPS_MIDDLE_CHUNKS=0

# --- HTML / Markdown：~10 KB ---
TRUNC_KIND_HTML_ENABLED=true
TRUNC_KIND_HTML_HEAD_MB=0.005
TRUNC_KIND_HTML_TAIL_MB=0.005
TRUNC_KIND_HTML_CHUNK_MB=0
TRUNC_KIND_HTML_MIDDLE_CHUNKS=0

TRUNC_KIND_MARKDOWN_ENABLED=true
TRUNC_KIND_MARKDOWN_HEAD_MB=0.005
TRUNC_KIND_MARKDOWN_TAIL_MB=0.005
TRUNC_KIND_MARKDOWN_CHUNK_MB=0
TRUNC_KIND_MARKDOWN_MIDDLE_CHUNKS=0

# --- 图片：converter 内部已对 OCR 结果做处理（保留全部 OCR 文本），
# 这里关闭通用截取（防误伤 OCR 文本，OCR 输出通常本来就不大）---
TRUNC_KIND_IMAGE_ENABLED=false
TRUNC_KIND_IMAGE_HEAD_MB=0
TRUNC_KIND_IMAGE_TAIL_MB=0
TRUNC_KIND_IMAGE_CHUNK_MB=0
TRUNC_KIND_IMAGE_MIDDLE_CHUNKS=0

# --- 可执行文件 / 压缩包：~1 KB 头部即可 ---
# converter 已经只输出头部元信息 + hex 摘要；这里再加一道 1KB 的硬限
TRUNC_KIND_EXE_ENABLED=true
TRUNC_KIND_EXE_HEAD_MB=0.001
TRUNC_KIND_EXE_TAIL_MB=0
TRUNC_KIND_EXE_CHUNK_MB=0
TRUNC_KIND_EXE_MIDDLE_CHUNKS=0

TRUNC_KIND_ARCHIVE_ZIP_ENABLED=true
TRUNC_KIND_ARCHIVE_ZIP_HEAD_MB=0.001
TRUNC_KIND_ARCHIVE_ZIP_TAIL_MB=0
TRUNC_KIND_ARCHIVE_ZIP_CHUNK_MB=0
TRUNC_KIND_ARCHIVE_ZIP_MIDDLE_CHUNKS=0

TRUNC_KIND_ARCHIVE_TAR_ENABLED=true
TRUNC_KIND_ARCHIVE_TAR_HEAD_MB=0.001
TRUNC_KIND_ARCHIVE_TAR_TAIL_MB=0
TRUNC_KIND_ARCHIVE_TAR_CHUNK_MB=0
TRUNC_KIND_ARCHIVE_TAR_MIDDLE_CHUNKS=0

TRUNC_KIND_ARCHIVE_7Z_ENABLED=true
TRUNC_KIND_ARCHIVE_7Z_HEAD_MB=0.001
TRUNC_KIND_ARCHIVE_7Z_TAIL_MB=0
TRUNC_KIND_ARCHIVE_7Z_CHUNK_MB=0
TRUNC_KIND_ARCHIVE_7Z_MIDDLE_CHUNKS=0

TRUNC_KIND_ARCHIVE_RAR_ENABLED=true
TRUNC_KIND_ARCHIVE_RAR_HEAD_MB=0.001
TRUNC_KIND_ARCHIVE_RAR_TAIL_MB=0
TRUNC_KIND_ARCHIVE_RAR_CHUNK_MB=0
TRUNC_KIND_ARCHIVE_RAR_MIDDLE_CHUNKS=0

TRUNC_KIND_ARCHIVE_GZ_ENABLED=true
TRUNC_KIND_ARCHIVE_GZ_HEAD_MB=0.001
TRUNC_KIND_ARCHIVE_GZ_TAIL_MB=0
TRUNC_KIND_ARCHIVE_GZ_CHUNK_MB=0
TRUNC_KIND_ARCHIVE_GZ_MIDDLE_CHUNKS=0

# --- 结构化文本：~10 KB ---
TRUNC_KIND_JSON_ENABLED=true
TRUNC_KIND_JSON_HEAD_MB=0.005
TRUNC_KIND_JSON_TAIL_MB=0.005
TRUNC_KIND_JSON_CHUNK_MB=0
TRUNC_KIND_JSON_MIDDLE_CHUNKS=0

TRUNC_KIND_CSV_ENABLED=true
TRUNC_KIND_CSV_HEAD_MB=0.005
TRUNC_KIND_CSV_TAIL_MB=0.005
TRUNC_KIND_CSV_CHUNK_MB=0
TRUNC_KIND_CSV_MIDDLE_CHUNKS=0

TRUNC_KIND_PARAM_ENABLED=true
TRUNC_KIND_PARAM_HEAD_MB=0.005
TRUNC_KIND_PARAM_TAIL_MB=0.005
TRUNC_KIND_PARAM_CHUNK_MB=0
TRUNC_KIND_PARAM_MIDDLE_CHUNKS=0

# --- 纯文本：~10 KB ---
TRUNC_KIND_TXT_ENABLED=true
TRUNC_KIND_TXT_HEAD_MB=0.005
TRUNC_KIND_TXT_TAIL_MB=0.005
TRUNC_KIND_TXT_CHUNK_MB=0
TRUNC_KIND_TXT_MIDDLE_CHUNKS=0

# --- 日志类：典型大文件，但截取后只保留 ~10 KB 头尾即可识别 ---
TRUNC_KIND_LOG_ENABLED=true
TRUNC_KIND_LOG_HEAD_MB=0.005
TRUNC_KIND_LOG_TAIL_MB=0.005
TRUNC_KIND_LOG_CHUNK_MB=0
TRUNC_KIND_LOG_MIDDLE_CHUNKS=0

TRUNC_KIND_TLOG_ENABLED=true
TRUNC_KIND_TLOG_HEAD_MB=0.005
TRUNC_KIND_TLOG_TAIL_MB=0.005
TRUNC_KIND_TLOG_CHUNK_MB=0
TRUNC_KIND_TLOG_MIDDLE_CHUNKS=0

TRUNC_KIND_RLOG_ENABLED=true
TRUNC_KIND_RLOG_HEAD_MB=0.005
TRUNC_KIND_RLOG_TAIL_MB=0.005
TRUNC_KIND_RLOG_CHUNK_MB=0
TRUNC_KIND_RLOG_MIDDLE_CHUNKS=0

# --- 代码类 ---
# 代码 code_* 走 TRUNC_DEFAULT_*（已设为 ~10 KB），无需在此重复声明


# ===========================================================================
# 十、按文件类型的大小筛选（SIZE_FILTER_*）=================================
# ---------------------------------------------------------------------------
# 关键策略：
#   - 默认下限 1 字节 → 把 0 字节文件全部踢掉（文件名乱+0字节 = 纯垃圾）
#   - 不设过大上限，让超大文件由 TRUNC_* 截取处理；避免误杀有价值大文件
# 任一值为 -1 / false / off / no / none / 空 → 关闭该项
# 优先级：扩展名(.xxx) > kind > default
# ===========================================================================

SIZE_FILTER_ENABLED=true

# --- 默认（关键点：MIN=0.000001 MB = 1 字节，即「严格 > 0」）---
# MIN=0 在工具内被语义化为「不限下限」；这里用一个极小正数表达「拒绝 0 字节」
SIZE_FILTER_DEFAULT_MIN_MB=0.000001
SIZE_FILTER_DEFAULT_MAX_MB=-1

# --- 按 kind 的大小筛选 ---

# 文档类：保留 > 0 字节、不设上限（大文件靠 TRUNC_* 处理）
SIZE_FILTER_KIND_PDF_MIN_MB=0.000001
SIZE_FILTER_KIND_PDF_MAX_MB=-1

SIZE_FILTER_KIND_DOCX_MIN_MB=0.000001
SIZE_FILTER_KIND_DOCX_MAX_MB=-1

SIZE_FILTER_KIND_XLSX_MIN_MB=0.000001
SIZE_FILTER_KIND_XLSX_MAX_MB=-1

SIZE_FILTER_KIND_WPS_MIN_MB=0.000001
SIZE_FILTER_KIND_WPS_MAX_MB=-1

SIZE_FILTER_KIND_MARKDOWN_MIN_MB=0.000001
SIZE_FILTER_KIND_MARKDOWN_MAX_MB=-1

SIZE_FILTER_KIND_HTML_MIN_MB=0.000001
SIZE_FILTER_KIND_HTML_MAX_MB=-1

# 图片：百度 OCR 限 4MB，所以 > 4MB 的图片即便启用 OCR 也会被跳过；
# 这里 size_filter 干脆挡掉 > 4MB 的图片（节省 hash 计算）。
# 下限 0.001 MB ≈ 1 KB，过小的图片基本是图标，没 OCR 价值
SIZE_FILTER_KIND_IMAGE_MIN_MB=0.001
SIZE_FILTER_KIND_IMAGE_MAX_MB=4

SIZE_FILTER_KIND_JSON_MIN_MB=0.000001
SIZE_FILTER_KIND_JSON_MAX_MB=-1

SIZE_FILTER_KIND_CSV_MIN_MB=0.000001
SIZE_FILTER_KIND_CSV_MAX_MB=-1

SIZE_FILTER_KIND_PARAM_MIN_MB=0.000001
SIZE_FILTER_KIND_PARAM_MAX_MB=-1

SIZE_FILTER_KIND_TXT_MIN_MB=0.000001
SIZE_FILTER_KIND_TXT_MAX_MB=-1

# 日志类：常见有几个 G 的大日志，但 TRUNC_KIND_LOG_* 会把它截到几 KB，
# 所以这里**不设**上限，让大日志也能进流水线（拿到头/中/尾很有价值）
SIZE_FILTER_KIND_LOG_MIN_MB=0.000001
SIZE_FILTER_KIND_LOG_MAX_MB=-1

SIZE_FILTER_KIND_TLOG_MIN_MB=0.000001
SIZE_FILTER_KIND_TLOG_MAX_MB=-1

SIZE_FILTER_KIND_RLOG_MIN_MB=0.000001
SIZE_FILTER_KIND_RLOG_MAX_MB=-1

# 可执行 / 压缩包：converter 只读头部，大文件不耗内存；但是 0 字节也要排除
SIZE_FILTER_KIND_EXE_MIN_MB=0.000001
SIZE_FILTER_KIND_EXE_MAX_MB=-1

SIZE_FILTER_KIND_ARCHIVE_ZIP_MIN_MB=0.000001
SIZE_FILTER_KIND_ARCHIVE_ZIP_MAX_MB=-1

SIZE_FILTER_KIND_ARCHIVE_TAR_MIN_MB=0.000001
SIZE_FILTER_KIND_ARCHIVE_TAR_MAX_MB=-1

SIZE_FILTER_KIND_ARCHIVE_7Z_MIN_MB=0.000001
SIZE_FILTER_KIND_ARCHIVE_7Z_MAX_MB=-1

SIZE_FILTER_KIND_ARCHIVE_RAR_MIN_MB=0.000001
SIZE_FILTER_KIND_ARCHIVE_RAR_MAX_MB=-1

SIZE_FILTER_KIND_ARCHIVE_GZ_MIN_MB=0.000001
SIZE_FILTER_KIND_ARCHIVE_GZ_MAX_MB=-1
